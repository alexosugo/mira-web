# Mixpanel — the site's single analytics tool. Project token from
# Mixpanel > Settings > Project Settings.
VITE_MIXPANEL_TOKEN=

# Optional: set to https://api-eu.mixpanel.com if your Mixpanel project is in
# the EU residency region. Leave blank for the default US endpoint.
VITE_MIXPANEL_API_HOST=

# Supabase — stores Elite "Get in touch" leads (see supabase/migrations).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
